.fish-loading-mask {
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  height: 100%;
  justify-content: center;
  left: 0;
  opacity: 0;
  pointer-events: none;
  position: fixed;
  top: 0;
  transition: opacity 0.2s ease;
  width: 100%;
  z-index: 9999;
}

.fish-loading-mask.visible {
  opacity: 1;
  pointer-events: auto;
}

.fish-loading-box {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fish-loading-icon {
  animation: fish-spin 1.1s linear infinite;
  height: 88rpx;
  width: 88rpx;
}

.fish-loading-text {
  color: #21B56B;
  font-size: 26rpx;
  font-weight: 500;
}

@keyframes fish-spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
