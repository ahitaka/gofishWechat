.community-page {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.tabs {
  background: #F7F8FA;
  display: flex;
  gap: 44rpx;
  padding: 0 32rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 5;
}

.tab {
  color: #777777;
  font-size: 30rpx;
  padding-bottom: 12rpx;
  position: relative;
}

.tab.active {
  color: #21B56B;
  font-weight: 600;
}

.tab.active::after {
  background: #21B56B;
  border-radius: 999rpx;
  bottom: 0;
  content: "";
  height: 6rpx;
  left: 18rpx;
  position: absolute;
  right: 18rpx;
}

.spot-filter {
  align-items: center;
  background: #EAF8F0;
  border-radius: 16rpx;
  color: #21B56B;
  display: flex;
  font-size: 26rpx;
  justify-content: space-between;
  margin: 0 32rpx 24rpx;
  padding: 18rpx 22rpx;
}

.spot-filter button {
  color: #21B56B;
  font-size: 24rpx;
}

.feed {
  padding: 0 32rpx;
}

.post-row {
  margin-bottom: 24rpx;
}
