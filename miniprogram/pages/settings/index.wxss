.settings-page {
  padding: 0 32rpx calc(180rpx + env(safe-area-inset-bottom));
}

.settings-page .nav {
  margin: 0 -32rpx;
}

/* 头像卡片 */
.avatar-card {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 48rpx 32rpx 36rpx;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-hint {
  color: #21B56B;
  font-size: 26rpx;
  margin-top: 20rpx;
}

/* 信息卡片 */
.info-card {
  margin-top: 24rpx;
  padding: 0 28rpx;
}

.row {
  align-items: center;
  display: flex;
  min-height: 100rpx;
}

.label {
  color: #222222;
  font-size: 30rpx;
  width: 140rpx;
}

.input {
  color: #333333;
  flex: 1;
  font-size: 30rpx;
  text-align: right;
}

.divider {
  background: #EEEEEE;
  height: 1rpx;
}

.row-right {
  align-items: center;
  display: flex;
  flex: 1;
  gap: 12rpx;
  justify-content: flex-end;
}

.value {
  color: #999999;
  font-size: 28rpx;
}

.arrow {
  color: #CCCCCC;
  font-size: 36rpx;
  line-height: 1;
}

.save-btn {
  margin-top: 48rpx;
}
