<view class="page settings-page">
  <view class="nav">
    <view class="nav-title">设置</view>
  </view>
  <!-- 头像卡片 -->
  <view class="card avatar-card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="chooseAvatar">
      <user-avatar src="{{avatarUrl || '/images/avatar.png'}}"></user-avatar>
    </button>
    <text class="avatar-hint">点击修改头像</text>
  </view>
  <!-- 信息列表 -->
  <view class="card info-card">
    <view class="row">
      <text class="label">昵称</text>
      <input class="input" type="nickname" value="{{nickname}}" maxlength="32" placeholder="请输入昵称" bindinput="setNickname" />
    </view>
    <view class="divider"></view>
    <view class="row" bindtap="chooseCover">
      <text class="label">主页封面</text>
      <view class="row-right">
        <text class="value">{{coverUrl ? '已设置' : '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
  <button class="primary-btn save-btn" loading="{{submitting}}" bindtap="save">保存</button>
  <bottom-nav></bottom-nav>
  <fish-loading></fish-loading>
</view>
