<view class="page user-profile-page" wx:if="{{user}}">
  <view class="nav">
    <view class="nav-title">用户主页</view>
  </view>
  <view class="profile-card card">
    <user-avatar src="{{user.avatarUrl || '/images/avatar.png'}}"></user-avatar>
    <view class="main">
      <view class="name">{{user.nickname}}</view>
      <view class="meta">Lv.{{user.level}} · 粉丝 {{user.followerCount}} · 关注 {{user.followingCount}}</view>
      <view class="bio" wx:if="{{user.bio}}">{{user.bio}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">公开钓点</view>
    <block wx:if="{{spots.length}}">
      <view wx:for="{{spots}}" wx:key="id" class="spot-row" data-id="{{item.id}}" bindtap="openSpot">
        <spot-card spot="{{item}}"></spot-card>
      </view>
    </block>
    <empty-state wx:else text="暂无公开钓点"></empty-state>
  </view>

  <view class="section">
    <view class="section-title">社区动态</view>
    <block wx:if="{{posts.length}}">
      <view wx:for="{{posts}}" wx:key="id" class="post-row" data-id="{{item.id}}" bindtap="openPost">
        <post-card post="{{item}}" bind:spot="openSpot" bind:preview="previewImage" bind:sharepost="sharePost"></post-card>
      </view>
    </block>
    <empty-state wx:else text="暂无公开动态"></empty-state>
  </view>
  <bottom-nav></bottom-nav>
  <fish-loading></fish-loading>
</view>
