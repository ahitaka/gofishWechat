.publish-page {
  padding: 0 32rpx calc(260rpx + env(safe-area-inset-bottom));
}

.publish-page .nav {
  margin: 0 -32rpx;
}

.type-tabs,
.visibility {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type,
.visibility view {
  background: #FFFFFF;
  border-radius: 16rpx;
  color: #777777;
  flex: 1;
  font-size: 26rpx;
  padding: 18rpx 0;
  text-align: center;
}

.type.active,
.visibility .active {
  background: #EAF8F0;
  color: #21B56B;
  font-weight: 500;
}

.form {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

textarea {
  color: #222222;
  font-size: 30rpx;
  min-height: 220rpx;
  width: 100%;
}

.images {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 20rpx;
}

.image,
.add-image {
  aspect-ratio: 1;
  background: #F7F8FA;
  border-radius: 16rpx;
  width: 100%;
}

.add-image {
  align-items: center;
  color: #21B56B;
  display: flex;
  font-size: 56rpx;
  justify-content: center;
}

.row {
  align-items: center;
  border-bottom: 1rpx solid #EEEEEE;
  display: flex;
  font-size: 28rpx;
  justify-content: space-between;
  min-height: 88rpx;
}

.value {
  color: #777777;
}

.spot-picker {
  border-bottom: 1rpx solid #EEEEEE;
  margin-bottom: 12rpx;
}

.spot-picker input {
  border-bottom: 0;
}

.spot-results {
  max-height: 300rpx;
}

.spot-option {
  border-top: 1rpx solid #F0F0F0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 18rpx 0;
}

.spot-option text:first-child {
  color: #222222;
  font-size: 28rpx;
  font-weight: 500;
}

.spot-option text:last-child,
.empty {
  color: #999999;
  font-size: 24rpx;
}

.spot-option.selected text:first-child {
  color: #21B56B;
}

input {
  border-bottom: 1rpx solid #EEEEEE;
  font-size: 28rpx;
  min-height: 88rpx;
}

.submit {
  margin: 32rpx 0 calc(120rpx + env(safe-area-inset-bottom));
}

.submit[disabled] {
  opacity: 0.72;
}
