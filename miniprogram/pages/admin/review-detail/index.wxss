.review-detail-page {
  padding: 0 32rpx calc(300rpx + env(safe-area-inset-bottom));
}

.review-detail-page .nav {
  margin: 0 -32rpx;
}

.main {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.tags {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.meta,
.reject {
  color: #777777;
  font-size: 26rpx;
  margin-top: 12rpx;
}

.reject {
  color: #E5484D;
}

.map {
  border-radius: 24rpx;
  height: 300rpx;
  width: 100%;
}
